{
    "_global_note": "This is the global MCP configuration (~/.claude/.mcp.json). Servers marked 'always-active' are enabled for all projects. Servers marked 'project-opt-in' are disabled by default \u2014 enable them in the project's .mcp.json or by providing the required credentials per project.",
    "mcpServers": {
        "fetch": {
            "command": "uvx",
            "args": [
                "mcp-server-fetch"
            ],
            "capabilities": [
                "fetch"
            ],
            "_tier": "always-active"
        },
        "sonarqube": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "SONAR_TOKEN",
                "-e",
                "SONAR_HOST_URL",
                "mcp/sonarqube"
            ],
            "env": {
                "SONAR_TOKEN": "${SONAR_TOKEN}",
                "SONAR_HOST_URL": "${SONAR_HOST_URL}"
            },
            "capabilities": [
                "static_analysis"
            ],
            "_tier": "project-opt-in",
            "_role": "First-class quality gate: run before every PR merge decision via pr-health-check and pr-readiness skills. Enable per project by providing SONAR_TOKEN and SONAR_HOST_URL.",
            "disabled": true
        },
        "codecov": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "CODECOV_TOKEN",
                "mcp/codecov"
            ],
            "env": {
                "CODECOV_TOKEN": "${CODECOV_TOKEN}"
            },
            "capabilities": [
                "coverage_reporting"
            ],
            "_tier": "project-opt-in",
            "_role": "Optional: enable when coverage trend tracking is required for PR merge decisions. Used by qa-agent acceptance-validation and pr-readiness skills.",
            "disabled": true
        },
        "slack": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "SLACK_BOT_TOKEN",
                "-e",
                "SLACK_TEAM_ID",
                "ghcr.io/chisanan232/slack-mcp-server:latest"
            ],
            "env": {
                "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
                "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
            },
            "_note": "[VERIFY IMAGE README] Confirm required env vars and runtime args at https://github.com/chisanan232/slack-mcp-server before enabling",
            "capabilities": [
                "communication"
            ],
            "_tier": "project-opt-in",
            "disabled": true
        },
        "clickup": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "CLICKUP_API_TOKEN",
                "ghcr.io/chisanan232/clickup-mcp-server:latest"
            ],
            "env": {
                "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}"
            },
            "_note": "[VERIFY IMAGE README] Confirm required env vars and runtime args at https://github.com/chisanan232/clickup-mcp-server before enabling",
            "_tier": "project-opt-in",
            "_role": "Enable when CLAUDE_ISSUE_TRACKER=clickup. Only one issue_tracking provider should be active at a time.",
            "capabilities": [
                "issue_tracking"
            ],
            "disabled": true
        },
        "jira": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "JIRA_URL",
                "-e",
                "JIRA_USERNAME",
                "-e",
                "JIRA_API_TOKEN",
                "ghcr.io/chisanan232/jira-mcp-server:latest"
            ],
            "env": {
                "JIRA_URL": "${JIRA_URL}",
                "JIRA_USERNAME": "${JIRA_USERNAME}",
                "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
            },
            "_note": "[VERIFY IMAGE README] Confirm required env vars and runtime args before enabling. JIRA_URL must be the full base URL (e.g. https://yourorg.atlassian.net). JIRA_USERNAME is the account email. JIRA_API_TOKEN is generated at https://id.atlassian.com/manage-profile/security/api-tokens",
            "_tier": "project-opt-in",
            "_role": "Enable when CLAUDE_ISSUE_TRACKER=jira. Set JIRA_URL, JIRA_USERNAME, and JIRA_API_TOKEN in .env. Only one issue_tracking provider should be active at a time.",
            "capabilities": [
                "issue_tracking"
            ],
            "disabled": true
        },
        "playwright": {
            "command": "npx",
            "args": [
                "@microsoft/playwright-mcp",
                "--browser",
                "chrome"
            ],
            "_tier": "project-opt-in",
            "_role": "Used by qa-agent for UI acceptance testing \u2014 navigate pages, interact with elements via accessibility tree, capture snapshots. Enable for projects with a web UI. Browser: chrome by default; override with --browser firefox|webkit|msedge.",
            "capabilities": [
                "browser_automation"
            ],
            "disabled": true
        },
        "datadog": {
            "command": "docker",
            "args": [
                "run",
                "--rm",
                "-i",
                "-e",
                "DD_API_KEY",
                "-e",
                "DD_APP_KEY",
                "mcp/datadog"
            ],
            "env": {
                "DD_API_KEY": "${DD_API_KEY}",
                "DD_APP_KEY": "${DD_APP_KEY}"
            },
            "capabilities": [
                "observability"
            ],
            "_tier": "project-opt-in",
            "disabled": true
        },
        "Framelink MCP for Figma": {
            "command": "npx",
            "args": [
                "-y",
                "figma-developer-mcp",
                "--figma-api-key=${FIGMA_API_KEY}",
                "--stdio"
            ]
        },
        "codebase-memory-mcp": {
            "command": "/Users/bryant/.nvm/versions/node/v23.11.0/lib/node_modules/codebase-memory-mcp/bin/codebase-memory-mcp"
        }
    }
}
